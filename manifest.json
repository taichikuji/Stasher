{
  "manifest_version": 3,
  "name": "Stasher",
  "version": "1.7.0",
  "description": "Yet Another Tab Manager by @taichikuji",
  "homepage_url": "https://github.com/taichikuji/Stasher",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "favicon",
    "contextMenus"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "action": {
    "default_title": "Click to Stash"
  },
  "commands": {
    "stash-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Stash current tabs"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "options_ui": {
    "page": "src/manager/manager.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  }
}